    // Main entry point with error handling and performance optimization
    static void Main(string[] args)
    {
        // Startup canary: Python checks for this line to detect antivirus interference.
        // If the process exits without printing this, the exe was likely blocked by AV.
        Console.WriteLine("COSMON_EXE_STARTED");
        Console.Out.Flush();

        // Set console output encoding to UTF-8 for proper Unicode character display
        // (e.g., box drawing characters, Greek letters like µ for microseconds)
        Console.OutputEncoding = System.Text.Encoding.UTF8;

        string outputFilePath = @"{{ output_file_path | replace('\\', '\\\\') }}";
        Dictionary<string, object> result;

        // OUTPUT SCHEMA CONTRACT:
        // Success: {"status": "success", "result": Dictionary<string, object>}
        // Error:   {"status": "error", "error_type": string, "message": string,
        //           "stack_trace": string?, "source": string?, "help_link": string?}
        // This schema is validated by Python Pydantic models (CSharpSuccessOutput/CSharpErrorOutput)

        // Set up interrupt handler for graceful timeout handling
        InterruptHandler.Setup();

        try
        {
            // Connect to SOLIDWORKS via ROT (Running Object Table).
            // The moniker (e.g. "SolidWorks_PID_12345") targets the exact
            // process that Python detected, which is essential when multiple
            // SOLIDWORKS versions are installed side-by-side.
            string rotMoniker = CompileTimeConfig.RotMoniker;
            ISldWorks swApp = ConnectViaROT(rotMoniker);

            if (swApp == null)
            {
                var ex = new InvalidOperationException(
                    "SOLIDWORKS ROT moniker '" + rotMoniker + "' not found. " +
                    "The SOLIDWORKS process may have been restarted since detection. " +
                    "Unexpected. Please re-try.");
                throw new ReportedException(ex.Message, ex);
            }

            // Execute user code within performance optimization context
            // This disables graphics updates, feature tree updates, and UI rendering
            // for maximum speed during script execution
            Dictionary<string, object> userResult;
            using (new InterruptHandler.PerformanceOptimizationScope(swApp))
            {
                userResult = main_impl(swApp);
            }

            // Validate the result contains only JSON-serializable types
            var visited = new HashSet<object>();
            var validateResult = ValidateJsonSerializable(userResult, "result", visited);

            if (!validateResult.Item1)
            {
                // Validation failed - check how to handle it
                string validationBehavior = System.Environment.GetEnvironmentVariable("CSHARP_VALIDATION_ERROR_MODE") ?? "propagate";
                
                // Assert valid configuration value
                if (!validationBehavior.Equals("propagate", StringComparison.OrdinalIgnoreCase) &&
                    !validationBehavior.Equals("handle", StringComparison.OrdinalIgnoreCase))
                {
                    throw new InvalidOperationException(
                        "Invalid CSHARP_VALIDATION_ERROR_MODE environment variable value: '" + validationBehavior + "'. " +
                        "Must be either 'propagate' or 'handle'."
                    );
                }
                
                if (validationBehavior.Equals("handle", StringComparison.OrdinalIgnoreCase))
                {
                    // Return error response directly
                    result = new Dictionary<string, object>
                    {
                        ["status"] = "error",
                        ["error_type"] = "System.InvalidOperationException",
                        ["message"] = "Cannot serialize result to JSON. " + validateResult.Item2,
                        ["stack_trace"] = "",
                        ["source"] = "",
                        ["help_link"] = "",
                        ["stack_frames"] = new List<Dictionary<string, object>>()
                    };
                }
                else
                {
                    // Throw exception to be caught by existing error handlers (default)
                    throw new InvalidOperationException(
                        "Cannot serialize result to JSON. " + validateResult.Item2
                    );
                }
            }
            else
            {
                // Wrap in success response
                result = new Dictionary<string, object>
                {
                    ["status"] = "success",
                    ["result"] = userResult
                };
            }
        }
        catch (ExecutionTimeoutException te)
        {
            // ExecutionTimeoutException raised outside user code
            // (if raised inside user code, it's wrapped in ReportedException)
            // Return clean error without throwing
            result = new Dictionary<string, object>
            {
                ["status"] = "error",
                ["error_type"] = typeof(ExecutionTimeoutException).FullName,
                ["message"] = te.Message,
                ["stack_trace"] = te.StackTrace ?? "",
                ["source"] = te.Source ?? "",
                ["help_link"] = te.HelpLink ?? "",
                ["stack_frames"] = new List<Dictionary<string, object>>()
            };
        }
        catch (ReportedException re)
        {
            // ReportedException is a signal to handle the INNER exception
            // Extract inner exception details and write to file
            Exception innerEx = re.InnerException;

            if (innerEx == null)
            {
                // Shouldn't happen, but handle gracefully
                innerEx = re;
            }

            // Extract structured stack trace information
            var stackFrames = new List<Dictionary<string, object>>();
            var stackTrace = new StackTrace(innerEx, true);

            for (int i = 0; i < stackTrace.FrameCount; i++)
            {
                var frame = stackTrace.GetFrame(i);
                if (frame == null) continue;

                var method = frame.GetMethod();
                if (method == null) continue;

                var frameDict = new Dictionary<string, object>
                {
                    ["file_name"] = frame.GetFileName() ?? "",
                    ["method_name"] = method.Name,
                    ["declaring_type"] = method.DeclaringType?.FullName ?? "",
                    ["line_number"] = frame.GetFileLineNumber(),
                    ["column_number"] = frame.GetFileColumnNumber()
                };

                stackFrames.Add(frameDict);
            }

            result = new Dictionary<string, object>
            {
                ["status"] = "error",
                ["error_type"] = innerEx.GetType().FullName,
                ["message"] = innerEx.Message,
                ["stack_trace"] = innerEx.StackTrace ?? "",
                ["source"] = innerEx.Source ?? "",
                ["help_link"] = innerEx.HelpLink ?? "",
                ["stack_frames"] = stackFrames
            };
        }
        // All other exceptions: let them crash and be caught via stderr

        // Serialize and write result to file
        try
        {
            var serializer = new JavaScriptSerializer();
            serializer.MaxJsonLength = int.MaxValue; // Allow large results

            string jsonOutput = serializer.Serialize(result);
            File.WriteAllText(outputFilePath, jsonOutput);
        }
        catch (Exception ex)
        {
            // This should rarely happen after validation, but could occur due to:
            // - Unexpected serialization edge cases
            // - File I/O errors (permissions, disk full, invalid path, etc.)
            Console.Error.WriteLine("FATAL: Failed to serialize or write result.");
            Console.Error.WriteLine("Error Type: " + ex.GetType().FullName);
            Console.Error.WriteLine("Error Message: " + ex.Message);
            Console.Error.WriteLine("Stack Trace: " + (ex.StackTrace ?? "No stack trace available"));
            throw;
        }
    }
