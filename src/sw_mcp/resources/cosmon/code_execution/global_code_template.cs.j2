// ========================================================================
// Standard Exception Types - Always available for error handling
// ========================================================================

/// <summary>
/// Custom exception wrapper that signals the inner exception should be handled gracefully
/// and returned to Python. This is purely a signal - the inner exception details are what
/// get returned, not the ReportedException itself.
///
/// Usage: throw new ReportedException("Error description", innerException);
/// </summary>
[Serializable]
public sealed class ReportedException : Exception
{
    public ReportedException(string message, Exception innerException)
        : base(message, innerException)
    {
    }

    // For remoting/serialization (e.g., across AppDomains or when logged/rehydrated)
    private ReportedException(SerializationInfo info, StreamingContext context)
        : base(info, context)
    {
    }
}

/// <summary>
/// Exception thrown when execution timeout is detected via graceful interrupt signal.
/// Allows user code to clean up resources before process termination.
/// </summary>
[Serializable]
public sealed class ExecutionTimeoutException : Exception
{
    public ExecutionTimeoutException(string message)
        : base(message)
    {
    }

    private ExecutionTimeoutException(SerializationInfo info, StreamingContext context)
        : base(info, context)
    {
    }
}

